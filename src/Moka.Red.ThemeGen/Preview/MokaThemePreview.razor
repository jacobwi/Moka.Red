@namespace Moka.Red.ThemeGen.Preview

<div class="moka-theme-preview" style="@PreviewStyle">
	<div class="moka-theme-preview__content">
		<div class="moka-theme-preview__section">
			<h4 class="moka-theme-preview__title">Buttons</h4>
			<div class="moka-theme-preview__row">
				<button class="moka-theme-preview__btn moka-theme-preview__btn--filled">Filled</button>
				<button class="moka-theme-preview__btn moka-theme-preview__btn--outlined">Outlined</button>
				<button class="moka-theme-preview__btn moka-theme-preview__btn--text">Text</button>
				<button class="moka-theme-preview__btn moka-theme-preview__btn--soft">Soft</button>
			</div>
		</div>

		<div class="moka-theme-preview__section">
			<h4 class="moka-theme-preview__title">Card</h4>
			<div class="moka-theme-preview__card">
				<h5 class="moka-theme-preview__card-title">Sample Card</h5>
				<p class="moka-theme-preview__card-text">
					This is a preview of how your theme looks applied to content. Typography, colors, and spacing are all driven by your theme tokens.
				</p>
			</div>
		</div>

		<div class="moka-theme-preview__section">
			<h4 class="moka-theme-preview__title">Input</h4>
			<div class="moka-theme-preview__input-group">
				<label class="moka-theme-preview__input-label">Sample Field</label>
				<input type="text" class="moka-theme-preview__input" placeholder="Type something..."/>
			</div>
		</div>

		<div class="moka-theme-preview__section">
			<h4 class="moka-theme-preview__title">Palette</h4>
			<div class="moka-theme-preview__palette">
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-primary)">
					<span>Primary</span>
				</div>
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-secondary)">
					<span>Secondary</span>
				</div>
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-error)">
					<span>Error</span>
				</div>
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-warning)">
					<span>Warning</span>
				</div>
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-success)">
					<span>Success</span>
				</div>
				<div class="moka-theme-preview__palette-item" style="background: var(--moka-color-info)">
					<span>Info</span>
				</div>
			</div>
		</div>

		<div class="moka-theme-preview__section">
			<h4 class="moka-theme-preview__title">Typography</h4>
			<div class="moka-theme-preview__typography">
				<span style="font-size: var(--moka-font-size-xxl); font-weight: var(--moka-font-weight-bold)">Heading XXL</span>
				<span style="font-size: var(--moka-font-size-xl)">Heading XL</span>
				<span style="font-size: var(--moka-font-size-lg)">Heading LG</span>
				<span style="font-size: var(--moka-font-size-md)">Body MD</span>
				<span style="font-size: var(--moka-font-size-base)">Body Base</span>
				<span style="font-size: var(--moka-font-size-sm)">Caption SM</span>
				<span style="font-size: var(--moka-font-size-xs)">Caption XS</span>
			</div>
		</div>
	</div>
</div>
