@namespace Moka.Red.Primitives.Utility
@inherits MokaComponentBase

<button class="@CssClass" style="@CssStyle" id="@Id"
        type="button"
        title="@(_copied ? CopiedText : TooltipText)"
        @onclick="HandleCopy"
        @attributes="AdditionalAttributes">
	@if (ChildContent is not null)
	{
		@ChildContent
	}
	else if (_copied)
	{
		<svg class="moka-copy-btn__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<polyline points="20 6 9 17 4 12"/>
		</svg>
	}
	else
	{
		<svg class="moka-copy-btn__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
		</svg>
	}
</button>
