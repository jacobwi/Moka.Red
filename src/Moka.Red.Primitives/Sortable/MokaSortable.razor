@namespace Moka.Red.Primitives.Sortable
@inherits MokaVisualComponentBase
@typeparam TItem

<div class="@CssClass" style="@CssStyle" id="@Id" @ref="_containerRef" @attributes="AdditionalAttributes">
	@foreach (var (item, index) in Items.Select((v, i) => (v, i)))
	{
		var disabled = IsItemDisabled?.Invoke(item) ?? false;
		<div class="moka-sortable-item @(disabled ? "moka-sortable-item--disabled" : "")"
		     data-index="@index" data-disabled="@(disabled ? "true" : "false")"
		     @key="ItemKey?.Invoke(item) ?? item">
			@if (DragHandle)
			{
				<span class="moka-sortable-handle" aria-hidden="true">
					<svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor" opacity="0.4">
						<circle cx="4" cy="3" r="1.3"/><circle cx="8" cy="3" r="1.3"/>
						<circle cx="4" cy="8" r="1.3"/><circle cx="8" cy="8" r="1.3"/>
						<circle cx="4" cy="13" r="1.3"/><circle cx="8" cy="13" r="1.3"/>
					</svg>
				</span>
			}
			@if (ItemTemplate is not null)
			{
				@ItemTemplate(item)
			}
			else
			{
				<span class="moka-sortable-item__text">@item?.ToString()</span>
			}
		</div>
	}
</div>
