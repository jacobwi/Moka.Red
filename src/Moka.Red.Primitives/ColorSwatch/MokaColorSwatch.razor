@namespace Moka.Red.Primitives.ColorSwatch
@inherits MokaVisualComponentBase

<div class="@CssClass" style="@CssStyle" id="@Id" @attributes="AdditionalAttributes">
	<div class="moka-color-swatch-grid">
		@foreach (var color in Colors)
		{
			<button type="button"
			        class="moka-color-swatch-item @ShapeClass @(color.Equals(SelectedColor, StringComparison.OrdinalIgnoreCase) ? "moka-color-swatch-item--selected" : "")"
			        style="background-color: @color;"
			        title="@color"
			        @onclick="() => HandleSelect(color)">
				@if (color.Equals(SelectedColor, StringComparison.OrdinalIgnoreCase))
				{
					<svg class="moka-color-swatch-check" width="12" height="12" viewBox="0 0 24 24"
					     fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
						<path d="M20 6L9 17l-5-5"/>
					</svg>
				}
			</button>
		}
		@if (AllowCustom)
		{
			@if (_showCustomInput)
			{
				<div class="moka-color-swatch-custom">
					<input type="color" value="@_customValue"
					       @oninput="e => _customValue = e.Value?.ToString() ?? string.Empty"/>
					<button type="button" class="moka-color-swatch-custom-ok" @onclick="HandleCustomConfirm">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
							<path d="M20 6L9 17l-5-5"/>
						</svg>
					</button>
					<button type="button" class="moka-color-swatch-custom-cancel" @onclick="() => _showCustomInput = false">
						<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
							<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
						</svg>
					</button>
				</div>
			}
			else
			{
				<button type="button" class="moka-color-swatch-add @ShapeClass" title="Custom color"
				        @onclick="HandleAddCustomClick">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none"
					     stroke="currentColor" stroke-width="2.5">
						<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
					</svg>
				</button>
			}
		}
	</div>
	@if (SelectedColor is not null)
	{
		<div class="moka-color-swatch-preview">
			<span class="moka-color-swatch-preview-dot" style="background: @SelectedColor;"></span>
			<span class="moka-color-swatch-preview-text">@SelectedColor</span>
		</div>
	}
</div>
