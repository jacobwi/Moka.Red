@namespace Moka.Red.Primitives.Media
@inherits MokaVisualComponentBase

<div class="@CssClass" style="@CssStyle" id="@Id" @attributes="AdditionalAttributes">
	@foreach (var item in Items)
	{
		<div class="moka-media-gallery-item" @onclick="() => HandleItemClick(item)">
			<img src="@GetThumbnailSrc(item)"
			     alt="@(item.Alt ?? "")"
			     loading="lazy"/>
			@if (ShowOverlay)
			{
				<div class="moka-media-gallery-overlay">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"/>
						<path d="M21 21l-4.35-4.35"/>
						<path d="M11 8v6"/>
						<path d="M8 11h6"/>
					</svg>
				</div>
			}
		</div>
	}
</div>

@if (_lightboxItem is not null)
{
	<div class="moka-lightbox" @onclick="CloseLightbox" @onkeydown="HandleLightboxKeyDown" tabindex="0">
		<div class="moka-lightbox-backdrop"></div>
		<div class="moka-lightbox-content" @onclick:stopPropagation="true">
			@if (_lightboxIndex > 0)
			{
				<button class="moka-lightbox-nav moka-lightbox-nav--prev" @onclick="LightboxPrev" type="button" aria-label="Previous">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
						<polyline points="15 18 9 12 15 6"/>
					</svg>
				</button>
			}
			<img src="@_lightboxItem.Src" alt="@(_lightboxItem.Alt ?? "")" class="moka-lightbox-image"/>
			@if (_lightboxIndex < Items.Count - 1)
			{
				<button class="moka-lightbox-nav moka-lightbox-nav--next" @onclick="LightboxNext" type="button" aria-label="Next">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
						<polyline points="9 6 15 12 9 18"/>
					</svg>
				</button>
			}
			@if (_lightboxItem.Caption is not null)
			{
				<div class="moka-lightbox-caption">@_lightboxItem.Caption</div>
			}
		</div>
		<button class="moka-lightbox-close" @onclick="CloseLightbox" type="button" aria-label="Close">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
			</svg>
		</button>
		<div class="moka-lightbox-counter">@(_lightboxIndex + 1) / @Items.Count</div>
	</div>
}
