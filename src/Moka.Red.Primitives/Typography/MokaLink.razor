@namespace Moka.Red.Primitives.Typography
@inherits MokaVisualComponentBase

<a class="@CssClass" style="@CssStyle" id="@Id"
   href="@Href"
   target="@(External ? "_blank" : null)"
   rel="@(External ? "noopener noreferrer" : null)"
   @attributes="AdditionalAttributes">
	@ChildContent
	@if (External)
	{
		<svg class="moka-link-external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
			<polyline points="15 3 21 3 21 9"/>
			<line x1="10" y1="14" x2="21" y2="3"/>
		</svg>
	}
</a>
