@namespace Moka.Red.Primitives.Icon
@inherits MokaVisualComponentBase

<svg class="@CssClass"
     style="display:inline-block;vertical-align:middle;flex-shrink:0;@CssStyle"
     id="@Id"
     viewBox="@Icon.ViewBox"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     aria-hidden="true"
     @attributes="AdditionalAttributes">
	<path d="@Icon.SvgPath"/>
</svg>
