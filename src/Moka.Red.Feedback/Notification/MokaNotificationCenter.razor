@namespace Moka.Red.Feedback.Notification
@inherits MokaComponentBase

<div class="@CssClass" style="@CssStyle" id="@Id" @attributes="AdditionalAttributes">
	<button class="moka-notification-bell" @onclick="TogglePanel" aria-label="Notifications">
		<MokaIcon Icon="MokaIcons.Status.Bell" SizeValue="18px"/>
		@if (NotificationService.UnreadCount > 0)
		{
			<span class="moka-notification-badge">@(NotificationService.UnreadCount > 99 ? "99+" : NotificationService.UnreadCount.ToString())</span>
		}
	</button>

	@if (_isOpen)
	{
		<div class="moka-notification-panel">
			<div class="moka-notification-panel__header">
				<span class="moka-notification-panel__title">Notifications</span>
				@if (NotificationService.Notifications.Count > 0)
				{
					<button class="moka-notification-panel__action" @onclick="HandleMarkAllRead">Mark all read</button>
					<button class="moka-notification-panel__action" @onclick="HandleClear">Clear all</button>
				}
			</div>

			<div class="moka-notification-panel__list">
				@if (NotificationService.Notifications.Count == 0)
				{
					<div class="moka-notification-panel__empty">
						<MokaIcon Icon="MokaIcons.Status.Bell" SizeValue="32px" Style="opacity: 0.3"/>
						<span>No notifications</span>
					</div>
				}
				else
				{
					@foreach (var notification in NotificationService.Notifications)
					{
						<div class="moka-notification-item @(notification.Read ? "" : "moka-notification-item--unread") moka-notification-item--@MokaEnumHelpers.ToCssClass(notification.Severity)"
						     @onclick="() => HandleItemClick(notification)">
							<div class="moka-notification-item__icon">
								<MokaIcon Icon="GetIcon(notification)" SizeValue="16px"/>
							</div>
							<div class="moka-notification-item__content">
								<div class="moka-notification-item__title">@notification.Title</div>
								<div class="moka-notification-item__message">@notification.Message</div>
								<div class="moka-notification-item__time">@FormatTime(notification.Timestamp)</div>
							</div>
							<button class="moka-notification-item__dismiss" @onclick="() => HandleRemove(notification.Id)"
							        @onclick:stopPropagation="true" aria-label="Dismiss">
								<MokaIcon Icon="MokaIcons.Navigation.Close" SizeValue="12px"/>
							</button>
						</div>
					}
				}
			</div>
		</div>
	}
</div>
