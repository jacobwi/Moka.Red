@namespace Moka.Red.Feedback.Dropdown
@inherits MokaComponentBase

@if (Divider)
{
	<div class="moka-dropdown-divider"></div>
}
else
{
	<div class="@CssClass" style="@CssStyle" role="menuitem"
	     aria-disabled="@(Disabled ? "true" : null)"
	     @onclick="HandleClick">
		@if (Icon is not null)
		{
			<MokaIcon Icon="Icon.Value" Size="MokaSize.Xs" class="moka-dropdown-item-icon"/>
		}
		@if (ChildContent is not null)
		{
			@ChildContent
		}
		else if (!string.IsNullOrEmpty(Text))
		{
			<span class="moka-dropdown-item-text">@Text</span>
		}
	</div>
}
