@namespace Moka.Red.Forms.TagInput
@inherits MokaVisualComponentBase

<MokaFieldWrapper Label="@Label"
                  HelperText="@HelperText"
                  ErrorText="@ErrorText"
                  HasError="@HasError"
                  Disabled="@Disabled"
                  Size="@Size">
	<div class="@ComputedCssClass" style="@Style">
		<div class="moka-taginput-container">
			@for (var i = 0; i < Values.Count; i++)
			{
				var index = i;
				var tag = Values[i];
				<span class="moka-taginput-tag">
					<span class="moka-taginput-tag-text">@tag</span>
					@if (!Disabled)
					{
						<button type="button"
						        class="moka-taginput-tag-dismiss"
						        @onclick="() => RemoveTag(index)"
						        tabindex="-1"
						        aria-label="@($"Remove {tag}")">
							<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
								<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
							</svg>
						</button>
					}
				</span>
			}
			@if (CanAddMore)
			{
				<input class="@InputCssClass"
				       type="text"
				       value="@_inputText"
				       @oninput="HandleInput"
				       @onkeydown="HandleKeyDown"
				       @onfocus="HandleFocus"
				       @onblur="HandleBlur"
				       placeholder="@(Values.Count == 0 ? Placeholder : "")"
				       disabled="@Disabled"
				       @attributes="AdditionalAttributes"/>
			}
		</div>
		@if (Clearable && Values.Count > 0 && !Disabled)
		{
			<button type="button"
			        class="moka-taginput-clear"
			        @onclick="HandleClearAll"
			        tabindex="-1"
			        aria-label="Clear all tags">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M18 6L6 18 M6 6l12 12"/>
				</svg>
			</button>
		}

		@if (_showSuggestions && FilteredSuggestions.Any())
		{
			<div class="moka-taginput-suggestions">
				@foreach (var suggestion in FilteredSuggestions)
				{
					<div class="moka-taginput-suggestion" @onmousedown="() => SelectSuggestion(suggestion)">
						@suggestion
					</div>
				}
			</div>
		}
	</div>
</MokaFieldWrapper>
