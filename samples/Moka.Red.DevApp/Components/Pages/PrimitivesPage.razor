		<MokaReveal Animation="MokaRevealAnimation.FadeUp">
			<MokaCard Title="Revealed Card" Outlined>
				<ChildContent>
					<MokaText>This card fades up into view when you scroll to it.</MokaText>
				</ChildContent>
			</MokaCard>
		</MokaReveal>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Log Viewer
     ============================================================ -->
<MokaCard Title="Log Viewer" Outlined Margin="MokaSpacingScale.Md" id="LogViewer">
	<ChildContent>
		<MokaLogViewer Entries="_logEntries" MaxHeight="300px"/>
	</ChildContent>
</MokaCard>

<!-- ============================================================
