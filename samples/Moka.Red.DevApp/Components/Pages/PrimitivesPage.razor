				<div style="width:40px;height:40px;background:var(--moka-color-surface-variant);border-radius:var(--moka-radius-md);"></div>
			</MokaBadge>
			<MokaBadge Content="3" Position="MokaBadgePosition.BottomRight">
				<div style="width:40px;height:40px;background:var(--moka-color-surface-variant);border-radius:var(--moka-radius-md);"></div>
			</MokaBadge>
