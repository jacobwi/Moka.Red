			<MokaFloatingActionButton Icon="MokaIcons.Action.Add" Extended="true" Label="New Item" OnClick="() => { }" Style="position:absolute;"/>
		</div>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Marquee
     ============================================================ -->
<MokaCard Title="Marquee" Subtitle="Scrolling text/content ticker" Style="margin-top: var(--moka-spacing-lg);" id="Marquee">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Scrolling Announcement</MokaHeading>
		<MokaMarquee>
			<MokaText>Breaking news: Moka.Red now includes Marquee, Number Ticker, Gauge, Confetti, and PIN Input components!</MokaText>
		</MokaMarquee>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Number Ticker
     ============================================================ -->
<MokaCard Title="Number Ticker" Subtitle="Animated rolling number counter" Style="margin-top: var(--moka-spacing-lg);" id="NumberTicker">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Counter with Increment</MokaHeading>
		<MokaFlexbox Align="MokaAlign.Center" Gap="MokaSpacingScale.Md">
			<MokaButton OnClick="() => _tickerValue += 100" Variant="MokaVariant.Outlined" Size="MokaSize.Sm">+100</MokaButton>
			<MokaNumberTicker Value="_tickerValue" Size="MokaSize.Lg" Color="MokaColor.Primary"/>
			<MokaButton OnClick="() => _tickerValue = 0" Variant="MokaVariant.Text" Size="MokaSize.Sm">Reset</MokaButton>
		</MokaFlexbox>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Gauge
     ============================================================ -->
<MokaCard Title="Gauge" Subtitle="Semicircular arc gauge" Style="margin-top: var(--moka-spacing-lg);" id="Gauge">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">CPU Usage</MokaHeading>
		<MokaGauge Value="72" Label="CPU Usage" Color="MokaColor.Primary"/>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Confetti
     ============================================================ -->
<MokaCard Title="Confetti" Subtitle="Celebration confetti burst" Style="margin-top: var(--moka-spacing-lg);" id="Confetti">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Trigger Confetti</MokaHeading>
		<MokaConfetti @bind-Active="_confettiActive"/>
		<MokaButton OnClick="() => _confettiActive = true" Color="MokaColor.Success">Celebrate!</MokaButton>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Code Block
     ============================================================ -->
<MokaCard Title="Code Block" Subtitle="Styled code display with line numbers and copy" Style="margin-top: var(--moka-spacing-lg);" id="CodeBlock">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">C# Sample</MokaHeading>
		<MokaCodeBlock Code="@_codeBlockSample" Language="csharp"/>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Swipe Actions
     ============================================================ -->
<MokaCard Title="Swipe Actions" Subtitle="Swipe to reveal actions on list items" Style="margin-top: var(--moka-spacing-lg);" id="SwipeActions">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Swipe Item</MokaHeading>
		<MokaText Size="MokaSize.Sm" Style="margin-bottom: var(--moka-spacing-sm);">@_swipeStatus</MokaText>
		<MokaSwipeActions>
			<LeftActions>
				<MokaButton Color="MokaColor.Success" Variant="MokaVariant.Filled" OnClick="HandleSwipeArchive">Archive</MokaButton>
			</LeftActions>
			<RightActions>
				<MokaButton Color="MokaColor.Error" Variant="MokaVariant.Filled" OnClick="HandleSwipeDelete">Delete</MokaButton>
			</RightActions>
			<ChildContent>
				<MokaCard Outlined Style="padding: var(--moka-spacing-md);">
					<MokaText>Swipe left or right to reveal actions</MokaText>
				</MokaCard>
			</ChildContent>
		</MokaSwipeActions>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Split Button
     ============================================================ -->
<MokaCard Title="Split Button" Subtitle="Button with dropdown arrow for secondary actions" Style="margin-top: var(--moka-spacing-lg);" id="SplitButton">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Basic</MokaHeading>
		<MokaFlexbox Gap="MokaSpacingScale.Md" Wrap="true">
			<MokaSplitButton OnClick="() => { }">Save</MokaSplitButton>
			<MokaSplitButton Color="MokaColor.Success" OnClick="() => { }">Publish</MokaSplitButton>
			<MokaSplitButton Color="MokaColor.Error" Variant="MokaVariant.Outlined" OnClick="() => { }">Delete</MokaSplitButton>
		</MokaFlexbox>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">With Dropdown</MokaHeading>
		<MokaSplitButton OnClick="@(() => _splitButtonStatus = "Primary action clicked")">
			<ChildContent>Save</ChildContent>
			<DropdownContent>
				<MokaDropdownItem Text="Save As..." Icon="MokaIcons.Action.Save" OnClick="@(() => _splitButtonStatus = "Save As clicked")"/>
				<MokaDropdownItem Text="Save Draft" Icon="MokaIcons.File.Document" OnClick="@(() => _splitButtonStatus = "Save Draft clicked")"/>
				<MokaDropdownItem Divider="true"/>
				<MokaDropdownItem Text="Export" Icon="MokaIcons.Action.Download" OnClick="@(() => _splitButtonStatus = "Export clicked")"/>
			</DropdownContent>
		</MokaSplitButton>
		<p style="margin-top:8px; opacity:0.6; font-size: var(--moka-font-size-sm);">@_splitButtonStatus</p>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Terminal
     ============================================================ -->
<MokaCard Title="Terminal" Subtitle="Console output display with colored lines and line numbers" Style="margin-top: var(--moka-spacing-lg);" id="Terminal">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Build Output</MokaHeading>
		<MokaTerminal Title="Build Output" Lines="_buildLines"/>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Colored Log with Line Numbers</MokaHeading>
		<MokaTerminal Title="deploy.log" ShowLineNumbers="true" ShowCopyButton="true" Lines="_logLines"/>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Fade In
     ============================================================ -->
<MokaCard Title="Fade In" Outlined Margin="MokaSpacingScale.Md" id="FadeIn">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Basic Fade</MokaHeading>
		<MokaFadeIn>
			<MokaCallout Type="MokaCalloutType.Note" Title="Welcome">
				This content fades in smoothly.
			</MokaCallout>
		</MokaFadeIn>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Fade Up</MokaHeading>
		<MokaFadeIn Direction="MokaFadeDirection.Up">
			<MokaCard Title="Feature Highlight" Outlined>
				<ChildContent>
					<MokaText>This card fades in while sliding up from below.</MokaText>
				</ChildContent>
			</MokaCard>
		</MokaFadeIn>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Slide In
     ============================================================ -->
<MokaCard Title="Slide In" Outlined Margin="MokaSpacingScale.Md" id="SlideIn">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Slide from Left</MokaHeading>
		<MokaSlideIn From="MokaSlideFrom.Left">
			<MokaCallout Type="MokaCalloutType.Note" Title="Navigation">
				This panel slides in from the left edge.
			</MokaCallout>
		</MokaSlideIn>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Slide from Bottom</MokaHeading>
		<MokaSlideIn From="MokaSlideFrom.Bottom">
			<MokaCard Title="Notification" Outlined>
				<ChildContent>
					<MokaText>This card slides up from the bottom.</MokaText>
				</ChildContent>
			</MokaCard>
		</MokaSlideIn>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Scale In
     ============================================================ -->
<MokaCard Title="Scale In" Outlined Margin="MokaSpacingScale.Md" id="ScaleIn">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Basic Scale In</MokaHeading>
		<MokaScaleIn>
			<MokaCard Title="Welcome" Outlined>
				<ChildContent>
					<MokaText>This card pops in from 80% scale.</MokaText>
				</ChildContent>
			</MokaCard>
		</MokaScaleIn>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Small Initial Scale</MokaHeading>
		<MokaScaleIn InitialScale="0.3">
			<MokaFlexbox Justify="MokaJustify.Center" Padding="MokaSpacingScale.Md">
				<MokaButton Color="MokaColor.Primary" Variant="MokaVariant.Filled">Pop!</MokaButton>
			</MokaFlexbox>
		</MokaScaleIn>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Stagger
     ============================================================ -->
<MokaCard Title="Stagger" Outlined Margin="MokaSpacingScale.Md" id="Stagger">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Staggered Fade In</MokaHeading>
		<MokaStagger Items="_staggerItems" Context="item">
			<ItemTemplate>
				<MokaCallout Type="MokaCalloutType.Note" Title="@item">A staggered item.</MokaCallout>
			</ItemTemplate>
		</MokaStagger>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Typewriter
     ============================================================ -->
<MokaCard Title="Typewriter" Outlined Margin="MokaSpacingScale.Md" id="Typewriter">
	<ChildContent>
		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Basic Typewriter</MokaHeading>
		<MokaTypewriter Text="Welcome to Moka.Red, a Blazor component library."/>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Fast Speed</MokaHeading>
		<MokaTypewriter Text="This text types very quickly!" Speed="20"/>

		<MokaHeading Level="3" Margin="MokaSpacingScale.Md">Looping</MokaHeading>
		<MokaTypewriter Text="Moka.Red" Speed="80" Loop ShowCursor/>
