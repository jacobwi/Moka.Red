		<MokaHeading Level="3" Margin="MokaSpacingScale.Sm">Company Hierarchy</MokaHeading>
		<MokaOrganizationChart TItem="OrgPerson" Root="_orgRoot">
			<ItemTemplate>
				<div style="text-align:center;">
					<strong>@context.Name</strong><br/>
					<span style="opacity:0.7; font-size: var(--moka-font-size-xs);">@context.Title</span>
				</div>
			</ItemTemplate>
		</MokaOrganizationChart>
