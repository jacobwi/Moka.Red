</MokaCard>

<!-- ============================================================
     Infinite Carousel
     ============================================================ -->
<MokaCard Title="Infinite Carousel" Outlined Margin="MokaSpacingScale.Md" id="InfiniteCarousel">
	<ChildContent>
		<MokaInfiniteCarousel Style="height: 200px;">
			<MokaCarouselSlide>
				<div style="display: flex; align-items: center; justify-content: center; height: 100%; background: var(--moka-color-primary); color: var(--moka-color-on-primary); font-size: var(--moka-font-size-lg);">Slide 1</div>
			</MokaCarouselSlide>
			<MokaCarouselSlide>
				<div style="display: flex; align-items: center; justify-content: center; height: 100%; background: var(--moka-color-secondary); color: var(--moka-color-on-secondary); font-size: var(--moka-font-size-lg);">Slide 2</div>
			</MokaCarouselSlide>
			<MokaCarouselSlide>
				<div style="display: flex; align-items: center; justify-content: center; height: 100%; background: var(--moka-color-success); color: var(--moka-color-on-success); font-size: var(--moka-font-size-lg);">Slide 3</div>
			</MokaCarouselSlide>
		</MokaInfiniteCarousel>
	</ChildContent>
</MokaCard>

<!-- ============================================================
     Parallax
     ============================================================ -->
<MokaCard Title="Parallax" Outlined Margin="MokaSpacingScale.Md" id="Parallax">
	<ChildContent>
		<MokaParallax Height="250px">
			<BackgroundContent>
				<div style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--moka-color-primary), var(--moka-color-secondary));"></div>
			</BackgroundContent>
			<ChildContent>
				<MokaFlexbox Align="MokaAlign.Center" Justify="MokaJustify.Center" Style="height: 100%;">
					<MokaHeading Level="3" Style="color: white;">Gradient Parallax</MokaHeading>
				</MokaFlexbox>
			</ChildContent>
		</MokaParallax>
	</ChildContent>
</MokaCard>

