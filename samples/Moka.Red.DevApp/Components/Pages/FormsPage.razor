@page "/forms"
@using Moka.Red.Forms.Base

<PageTitle>Forms — Moka.Red</PageTitle>

<h1>Forms</h1>
<p class="page-desc">All form inputs: TextField, Password, Numeric, TextArea, Checkbox, Switch, Select, DatePicker, TimePicker, ColorPicker, FileUpload, AutoComplete, Slider, Rating, TagInput, RadioGroup, OTP, Phone, Search, CreditCard, Currency, and SignaturePad.</p>

<!-- ============================================================
     Form Inputs Showcase
     ============================================================ -->
<section class="token-section">
	<h2 id="TextField">Form Inputs</h2>

	<EditForm Model="@_model" style="display: flex; flex-direction: column; gap: var(--moka-spacing-lg); max-width: 480px;">

		<h3>MokaTextField</h3>
		<MokaTextField @bind-Value="_model.Name" Label="Name" Placeholder="Enter your name" HelperText="Your full name"/>
		<MokaTextField @bind-Value="_model.Email" Label="Email" Placeholder="user@example.com" StartIcon="MokaIcons.Action.Search"/>
		<MokaTextField @bind-Value="_model.Name" Label="Clearable" Placeholder="Type something..." Clearable="true"/>
		<MokaTextField @bind-Value="_model.Name" Label="With Error" Placeholder="Invalid input" ErrorText="This field is required."/>
		<MokaTextField @bind-Value="_model.Name" Label="Disabled" Placeholder="Cannot edit" Disabled="true"/>

		<h3>TextField Sizes</h3>
		<MokaTextField @bind-Value="_model.Name" Label="Small" Size="MokaSize.Sm" Placeholder="Small input"/>
		<MokaTextField @bind-Value="_model.Name" Label="Medium" Size="MokaSize.Md" Placeholder="Medium input"/>
		<MokaTextField @bind-Value="_model.Name" Label="Large" Size="MokaSize.Lg" Placeholder="Large input"/>

		<h3 id="PasswordField">MokaPasswordField</h3>
		<MokaPasswordField @bind-Value="_model.Password" Label="Password" Placeholder="Enter password" HelperText="At least 8 characters"/>
		<MokaPasswordField @bind-Value="_model.Password" Label="No Toggle" Placeholder="Hidden only" ShowToggle="false"/>
		<MokaPasswordField @bind-Value="_model.Password" Label="With Error" Placeholder="Too short" ErrorText="Password must be at least 8 characters."/>

		<h3 id="NumericField">MokaNumericField</h3>
		<MokaNumericField @bind-Value="_model.Age" Label="Age" Placeholder="Enter your age" TValue="int"/>
		<MokaNumericField @bind-Value="_model.Age" Label="With Error" ErrorText="Must be between 1 and 120." TValue="int"/>
		<MokaNumericField @bind-Value="_model.Age" Label="Disabled" Disabled="true" TValue="int"/>

		<h3 id="TextArea">MokaTextArea</h3>
		<MokaTextArea @bind-Value="_model.Bio" Label="Bio" Placeholder="Tell us about yourself..." HelperText="Max 500 characters" Rows="4" MaxLength="500"/>
		<MokaTextArea @bind-Value="_model.Bio" Label="With Error" Placeholder="Required field" ErrorText="Bio is required." Rows="3"/>
		<MokaTextArea @bind-Value="_model.Bio" Label="Disabled" Placeholder="Cannot edit" Disabled="true" Rows="2"/>

		<h3 id="Checkbox">MokaCheckbox</h3>
		<MokaCheckbox @bind-Value="_model.AgreeTerms" Label="I agree to the terms and conditions"/>
		<MokaCheckbox @bind-Value="_model.AgreeTerms" Label="Label Before" LabelPlacement="MokaToggleBase.LabelPosition.Before"/>
		<MokaCheckbox @bind-Value="_model.AgreeTerms" Label="Indeterminate" Indeterminate="true"/>
		<MokaCheckbox @bind-Value="_model.AgreeTerms" Label="Disabled" Disabled="true"/>

		<h3 id="Switch">MokaSwitch</h3>
		<MokaSwitch @bind-Value="_model.DarkMode" Label="Dark Mode"/>
		<MokaSwitch @bind-Value="_model.DarkMode" Label="Label Before" LabelPlacement="MokaToggleBase.LabelPosition.Before"/>
		<MokaSwitch @bind-Value="_model.DarkMode" Label="Disabled" Disabled="true"/>

		<h3 id="SelectField">MokaSelect</h3>
		<MokaSelect @bind-Value="_model.Country" Items="@_countries" Label="Country" Placeholder="Select a country..." TValue="string"/>
		<MokaSelect @bind-Value="_model.Country" Items="@_countries" Label="Searchable" Placeholder="Search countries..." Searchable="true" TValue="string"/>
		<MokaSelect @bind-Value="_model.Country" Items="@_countries" Label="Clearable" Placeholder="Select..." Clearable="true" TValue="string"/>
		<MokaSelect @bind-Value="_model.Country" Items="@_countries" Label="With Error" ErrorText="Please select a country." TValue="string"/>
		<MokaSelect @bind-Value="_model.Country" Items="@_countries" Label="Disabled" Disabled="true" TValue="string"/>

		<h3>MokaSelect — Multiple</h3>
		<MokaSelect TValue="string" Items="@_countries" Label="Multi-Select" Placeholder="Choose countries..." Multiple="true" Clearable="true"
		            SelectedValues="_selectedCountries" SelectedValuesChanged="v => _selectedCountries = v"/>
		<p style="font-size: var(--moka-font-size-xs); opacity: 0.6;">Selected: @string.Join(", ", _selectedCountries)</p>

		<h3>MokaSelect — Loading</h3>
		<MokaSelect TValue="string" Items="@_countries" Label="Loading State" Loading="true" Placeholder="Fetching data..."/>
	</EditForm>
</section>

<!-- ============================================================
     Advanced Form Inputs Showcase
     ============================================================ -->
<section class="token-section">
	<h2 id="DatePicker">Advanced Form Inputs</h2>

	<EditForm Model="@_model" style="display: flex; flex-direction: column; gap: var(--moka-spacing-lg); max-width: 480px;">
		<h3>MokaDatePicker</h3>
		<MokaDatePicker @bind-Value="_selectedDate" Label="Date"/>
		<MokaDatePicker @bind-Value="_selectedDate2" Label="With Min/Max" Min="DateTime.Today.AddDays(-30)" Max="DateTime.Today.AddDays(30)"/>
		<MokaDatePicker @bind-Value="_selectedDate" Label="Custom Format" Format="dd/MM/yyyy" Placeholder="DD/MM/YYYY"/>
		<MokaDatePicker @bind-Value="_selectedDate" Label="Disabled" Disabled="true"/>
		<p style="font-size: var(--moka-font-size-xs); opacity: 0.6;">Selected: @(_selectedDate?.ToString("yyyy-MM-dd") ?? "none")</p>

		<h3 id="TimePicker">MokaTimePicker</h3>
		<MokaTimePicker @bind-Value="_selectedTime" Label="Time (24h)"/>
		<MokaTimePicker @bind-Value="_selectedTime2" Label="Time (12h)" Format24="false"/>
		<MokaTimePicker @bind-Value="_selectedTime" Label="15-min Steps" MinuteStep="15"/>
		<MokaTimePicker @bind-Value="_selectedTime" Label="Disabled" Disabled="true"/>
		<p style="font-size: var(--moka-font-size-xs); opacity: 0.6;">Selected: @(_selectedTime?.ToString(@"hh\:mm") ?? "none")</p>

		<h3 id="ColorPicker">MokaColorPicker</h3>
		<MokaColorPicker @bind-Value="_selectedColor" Label="Color (drag gradient & sliders)"/>
		<MokaColorPicker @bind-Value="_selectedColor2" Label="With Alpha" ShowAlpha="true"/>
		<MokaColorPicker @bind-Value="_selectedColor" Label="Hex Only (no RGB)" ShowRgbInputs="false"/>
		<MokaColorPicker @bind-Value="_selectedColor" Label="Minimal" ShowEyeDropper="false" ShowCopyButton="false" ShowRgbInputs="false" ShowRecentColors="false"/>
		<MokaColorPicker @bind-Value="_selectedColor" Label="Disabled" Disabled="true"/>
		<p style="font-size: var(--moka-font-size-xs); opacity: 0.6;">Selected: @_selectedColor</p>

		<h3 id="FileUpload">MokaFileUpload</h3>
		<MokaFileUpload Label="Upload Files" Multiple="true"/>
		<MokaFileUpload Label="Images Only" Accept="image/*" HelperText="Accepts image files only"/>
		<MokaFileUpload Label="Compact Mode" Compact="true"/>
		<MokaFileUpload Label="Disabled" Disabled="true"/>
	</EditForm>
</section>

<!-- ============================================================
     Additional Form Inputs Showcase
     ============================================================ -->
<section class="token-section">
	<h2>Additional Form Inputs</h2>

	<h3 id="AutoComplete">MokaAutoComplete</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;">
		<div style="width: 250px;">
			<MokaAutoComplete TItem="string"
			                  @bind-Value="_autoCompleteValue"
			                  SearchFunc="SearchCountries"
			                  Label="Country"
			                  Placeholder="Search countries..."
			                  HelperText="@($"Selected: {_autoCompleteValue ?? "none"}")"/>
		</div>
	</div>

	<h3 id="Slider">MokaSlider</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;">
		<div style="width: 300px;">
			<MokaSlider @bind-Value="_sliderValue" Label="Volume" ShowMinMax="true"/>
		</div>
		<div style="width: 300px;">
			<MokaSlider @bind-Value="_sliderValue" Label="Precise" Min="0" Max="1" Step="0.01" ValueFormat="P0"/>
		</div>
	</div>

	<h3 id="RangeSlider">MokaRangeSlider</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;">
		<div style="width: 300px;">
			<MokaRangeSlider @bind-ValueStart="_rangeStart" @bind-ValueEnd="_rangeEnd" Label="Price Range"/>
		</div>
	</div>

	<h3 id="Rating">MokaRating</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: center;">
		<MokaRating @bind-Value="_rating" Label="Rating" ShowValue="true"/>
		<MokaRating @bind-Value="_rating" Label="Large" Size="MokaSize.Lg"/>
		<MokaRating Value="4" ReadOnly="true" Label="Read Only"/>
	</div>

	<h3 id="TagInput">MokaTagInput</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;">
		<div style="width: 350px;">
			<MokaTagInput @bind-Values="_tags" Label="Technologies" HelperText="Press Enter or comma to add"/>
		</div>
	</div>

	<h3 id="RadioGroup">MokaRadioGroup</h3>
	<div class="demo-row" style="display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start;">
		<MokaRadioGroup TValue="string" @bind-Value="_radioValue" Label="Choose an option">
			<MokaRadioItem TValue="string" Value="@("option1")" Label="Option 1"/>
			<MokaRadioItem TValue="string" Value="@("option2")" Label="Option 2"/>
			<MokaRadioItem TValue="string" Value="@("option3")" Label="Option 3"/>
		</MokaRadioGroup>
		<MokaRadioGroup TValue="string" @bind-Value="_radioValue" Label="Horizontal" Orientation="MokaDirection.Row">
			<MokaRadioItem TValue="string" Value="@("option1")" Label="Option 1"/>
			<MokaRadioItem TValue="string" Value="@("option2")" Label="Option 2"/>
			<MokaRadioItem TValue="string" Value="@("option3")" Label="Option 3"/>
		</MokaRadioGroup>
	</div>
</section>

<!-- ============================================================
     Commerce & Data Entry Components
     ============================================================ -->
<section class="token-section">
	<h2>Commerce & Data Entry</h2>

	<h3 id="CreditCardInput">Credit Card Input</h3>
	<MokaCreditCardInput @bind-CardNumber="_ccNumber"
	                     @bind-ExpiryDate="_ccExpiry"
	                     @bind-Cvv="_ccCvv"
	                     @bind-CardholderName="_ccName"
	                     OnCardTypeDetected="t => _ccType = t"/>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Detected: @(_ccType ?? "unknown")
	</p>

	<h3 id="CurrencyInput" style="margin-top: 16px;">Currency Input</h3>
	<div style="max-width: 240px;">
		<MokaCurrencyInput @bind-Value="_currencyUsd" Label="Amount (USD)" CurrencySymbol="$" CurrencyCode="USD"/>
	</div>
	<div style="max-width: 240px; margin-top: 8px;">
		<MokaCurrencyInput @bind-Value="_currencyEur" Label="Amount (EUR)" CurrencySymbol="&euro;" CurrencyCode="EUR"/>
	</div>

	<h3 id="PriceDisplay" style="margin-top: 16px;">Price Display</h3>
	<div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
		<MokaPriceDisplay Price="29.99m"/>
		<MokaPriceDisplay Price="19.99m" OriginalPrice="29.99m"/>
		<MokaPriceDisplay Price="9.99m" OriginalPrice="49.99m" Highlight="true"/>
		<MokaPriceDisplay Price="199.00m" CurrencyCode="EUR" CurrencySymbol="&euro;"/>
	</div>

	<h3 id="OtpInput" style="margin-top: 16px;">OTP Input</h3>
	<MokaOtpInput @bind-Value="_otpValue" Label="Verification Code" HelperText="Enter the 6-digit code" OnComplete="v => _otpComplete = v"/>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Value: @_otpValue @(_otpComplete is not null ? $" (Complete: {_otpComplete})" : "")
	</p>

	<h3 id="PhoneInput" style="margin-top: 16px;">Phone Input</h3>
	<div style="max-width: 280px;">
		<MokaPhoneInput @bind-Value="_phoneValue" Label="Phone Number"/>
	</div>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Value: @_phoneValue
	</p>

	<h3 id="SearchInput" style="margin-top: 16px;">Search Input</h3>
	<div style="max-width: 320px;">
		<MokaSearchInput @bind-Value="_searchValue" ShowShortcut="true" Loading="_searchLoading" OnSearch="HandleSearchDemo"/>
	</div>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Search: @_searchValue
	</p>
</section>

<!-- ============================================================
     Signature Pad
     ============================================================ -->
<section class="token-section">
	<h2 id="SignaturePad">MokaSignaturePad</h2>
	<MokaSignaturePad @bind-Value="_signatureValue"
	                  Label="Customer Signature"
	                  HelperText="Please sign within the box above"
	                  Height="200px"/>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Has signature: @(!string.IsNullOrEmpty(_signatureValue))
	</p>
</section>

<!-- ============================================================
     Calendar Showcase
     ============================================================ -->
<section class="token-section">
	<h2 id="Calendar">Calendar</h2>

	<h3>Basic Calendar</h3>
	<div style="max-width: 320px;">
		<MokaCalendar @bind-Value="_calendarDate" HighlightToday/>
	</div>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Selected: @(_calendarDate?.ToString("yyyy-MM-dd") ?? "none")
	</p>

	<h3 style="margin-top: 16px;">With Min/Max Dates</h3>
	<div style="max-width: 320px;">
		<MokaCalendar @bind-Value="_calendarDate2"
		              MinDate="@(DateOnly.FromDateTime(DateTime.Today.AddDays(-14)))"
		              MaxDate="@(DateOnly.FromDateTime(DateTime.Today.AddDays(14)))"
		              HighlightToday/>
	</div>
	<p style="font-size: var(--moka-font-size-xs); opacity: 0.6; margin-top: 4px;">
		Selected: @(_calendarDate2?.ToString("yyyy-MM-dd") ?? "none") (restricted to +/- 14 days)
	</p>

	<h3 style="margin-top: 16px;">Monday First Day</h3>
	<div style="max-width: 320px;">
		<MokaCalendar @bind-Value="_calendarDate" FirstDayOfWeek="DayOfWeek.Monday" Color="MokaColor.Info"/>
	</div>
</section>

<!-- ============================================================
     Input Group Showcase
     ============================================================ -->
<section class="token-section">
	<h2 id="InputGroup">Input Group</h2>

	<h3>Search with Button</h3>
	<div style="max-width: 400px;">
		<MokaInputGroup>
			<MokaTextField @bind-Value="_groupSearchValue" Placeholder="Search..."/>
			<MokaButton StartIcon="MokaIcons.Action.Search">Search</MokaButton>
		</MokaInputGroup>
	</div>

	<h3 style="margin-top: 16px;">URL Input with Protocol</h3>
	<div style="max-width: 400px;">
		<MokaInputGroup>
			<MokaButton Variant="MokaVariant.Outlined" Disabled>https://</MokaButton>
			<MokaTextField @bind-Value="_groupUrlValue" Placeholder="example.com"/>
		</MokaInputGroup>
	</div>

	<h3 style="margin-top: 16px;">Small Size</h3>
	<div style="max-width: 350px;">
		<MokaInputGroup Size="MokaSize.Sm">
			<MokaTextField @bind-Value="_groupSmallValue" Placeholder="Enter value..."/>
			<MokaButton Color="MokaColor.Primary" Size="MokaSize.Sm">Go</MokaButton>
		</MokaInputGroup>
	</div>
</section>

<!-- ============================================================
     MokaTreeSelect
     ============================================================ -->
<section class="token-section">
	<h2 id="TreeSelect">MokaTreeSelect</h2>

	<h3>Basic Tree Select</h3>
	<div style="max-width: 350px;">
		<MokaTreeSelect TValue="string"
		                @bind-Value="_treeSelectValue"
		                Label="Category"
		                Placeholder="Choose a category..."
		                Items="_treeSelectItems"/>
		<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected: @(_treeSelectValue ?? "none")</MokaText>
	</div>
</section>

<!-- ============================================================
     MokaColorWheel
     ============================================================ -->
<section class="token-section">
	<h2 id="ColorWheel">MokaColorWheel</h2>

	<h3>Basic Color Wheel</h3>
	<MokaColorWheel @bind-Value="_colorWheelValue"/>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected: @_colorWheelValue</MokaText>
</section>

<!-- ============================================================
     PIN Input
     ============================================================ -->
<section>
	<h2 id="PinInput">MokaPinInput</h2>

	<h3>4-Digit Masked PIN</h3>
	<MokaPinInput @bind-Value="_pinValue" OnComplete="HandlePinComplete"/>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">
		@(_pinComplete ?? "Enter all 4 digits...")
	</MokaText>
</section>

<!-- ============================================================
     Password Strength
     ============================================================ -->
<section>
	<h2 id="PasswordStrength">MokaPasswordStrength</h2>

	<h3>Strength Indicator</h3>
	<div style="max-width: 400px;">
		<MokaTextField @bind-Value="_strengthPassword" Label="Password" Placeholder="Type a password..."/>
		<MokaPasswordStrength Password="@_strengthPassword" ShowRequirements="true" RequireSpecial="true"/>
	</div>
</section>

<!-- ============================================================
     Form Builder
     ============================================================ -->
<section>
	<h2 id="FormBuilder">MokaFormBuilder</h2>

	<h3>Basic Form Builder</h3>
	<MokaFormBuilder @bind-Fields="_builderFields" ExportFormat="MokaFormExportFormat.Razor"/>
</section>

<!-- ============================================================
     Knob
     ============================================================ -->
<section>
	<h2 id="Knob">MokaKnob</h2>

	<h3>Basic Knob</h3>
	<MokaFlexbox Direction="MokaDirection.Row" Gap="MokaSpacingScale.Xl" Align="MokaAlign.End" Wrap>
		<MokaKnob @bind-Value="_knobValue"/>
		<MokaKnob @bind-Value="_knobValue" Label="Volume"/>
		<MokaKnob @bind-Value="_knobValue" Label="Gain" Color="MokaColor.Success"/>
	</MokaFlexbox>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Value: @_knobValue</MokaText>
</section>

<!-- ============================================================
     Color Input
     ============================================================ -->
<section>
	<h2 id="ColorInput">MokaColorInput</h2>

	<h3>Basic Color Input</h3>
	<div style="max-width: 300px;">
		<MokaColorInput @bind-Value="_colorInputValue" Label="Brand Color" HelperText="Pick a hex color"/>
		<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected: @_colorInputValue</MokaText>
	</div>
</section>

<!-- ============================================================
     Date Range Picker
     ============================================================ -->
<section>
	<h2 id="DateRangePicker">MokaDateRangePicker</h2>

	<h3>Basic Date Range</h3>
	<div style="max-width: 400px;">
		<MokaDateRangePicker @bind-StartDate="_rangeStartDate" @bind-EndDate="_rangeEndDate" Label="Date Range"/>
		<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">
			Start: @(_rangeStartDate?.ToString("yyyy-MM-dd") ?? "none") | End: @(_rangeEndDate?.ToString("yyyy-MM-dd") ?? "none")
		</MokaText>
	</div>
</section>

<!-- ============================================================
     Toggle Group
     ============================================================ -->
<section>
	<h2 id="ToggleGroup">MokaToggleGroup</h2>

	<h3>Single Select</h3>
	<MokaToggleGroup @bind-Value="_toggleGroupValue">
		<MokaToggleGroupItem Value="list" Text="List"/>
		<MokaToggleGroupItem Value="grid" Text="Grid"/>
		<MokaToggleGroupItem Value="board" Text="Board"/>
	</MokaToggleGroup>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected: @(_toggleGroupValue ?? "none")</MokaText>

	<h3 style="margin-top: 16px;">Multi Select</h3>
	<MokaToggleGroup @bind-Values="_toggleGroupValues" Multiple="true" Color="MokaColor.Secondary">
		<MokaToggleGroupItem Value="bold" Text="Bold"/>
		<MokaToggleGroupItem Value="italic" Text="Italic"/>
		<MokaToggleGroupItem Value="underline" Text="Underline"/>
	</MokaToggleGroup>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected: @string.Join(", ", _toggleGroupValues)</MokaText>
</section>

<!-- ============================================================
     IP Address Input
     ============================================================ -->
<section>
	<h2 id="IpAddressInput">MokaIpAddressInput</h2>

	<h3>With Label</h3>
	<MokaIpAddressInput @bind-Value="_ipAddress" Label="Server IP" HelperText="Enter the target server address"/>

	<h3 style="margin-top: 16px;">Disabled</h3>
	<MokaIpAddressInput Value="10.0.0.1" Label="Gateway" Disabled="true"/>
</section>

<!-- ============================================================
     MAC Address Input
     ============================================================ -->
<section>
	<h2 id="MacAddressInput">MokaMacAddressInput</h2>

	<h3>With Label</h3>
	<MokaMacAddressInput @bind-Value="_macAddress" Label="Device MAC" HelperText="Enter the hardware address"/>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Value: @(_macAddress ?? "none")</MokaText>
</section>

<!-- ============================================================
     Schedule Picker
     ============================================================ -->
<section>
	<h2 id="SchedulePicker">MokaSchedulePicker</h2>

	<h3>Weekday 9-5</h3>
	<MokaSchedulePicker @bind-SelectedSlots="_scheduleSlots"/>
	<MokaText Size="MokaSize.Sm" Style="margin-top:8px; opacity:0.6;">Selected slots: @_scheduleSlots.Count</MokaText>
</section>

@code {

	// DateRangePicker demo fields
	private DateOnly? _rangeStartDate = DateOnly.FromDateTime(DateTime.Today);
	private DateOnly? _rangeEndDate = DateOnly.FromDateTime(DateTime.Today.AddDays(7));

	// ToggleGroup demo fields
	private string? _toggleGroupValue = "list";
	private IReadOnlyList<string> _toggleGroupValues = new[] { "bold" };

	// Calendar demo fields
	private DateOnly? _calendarDate = DateOnly.FromDateTime(DateTime.Today);
	private DateOnly? _calendarDate2;

	// Input group demo fields
	private string _groupSearchValue = "";
	private string _groupUrlValue = "";
	private string _groupSmallValue = "";

	// Form demo model
	private readonly FormModel _model = new();
	private static readonly string[] _countries = ["United States", "United Kingdom", "Canada", "Australia", "Germany", "France", "Japan"];

	private sealed class FormModel
	{
		public string Name { get; set; } = "";
		public string Email { get; set; } = "";
		public string Password { get; set; } = "";
		public int Age { get; set; }
		public string Bio { get; set; } = "";
		public bool AgreeTerms { get; set; }
		public bool DarkMode { get; set; }
		public string Country { get; set; } = "";
	}

	// Select demo fields
	private IList<string> _selectedCountries = new List<string>();

	// Advanced form demo fields
	private DateTime? _selectedDate = DateTime.Today;
	private DateTime? _selectedDate2;
	private TimeSpan? _selectedTime = new TimeSpan(14, 30, 0);
	private TimeSpan? _selectedTime2;
	private string _selectedColor = "#d32f2f";
	private string _selectedColor2 = "#1976d2";

	// Additional form inputs
	private string? _autoCompleteValue;
	private static readonly string[] _allCountries = ["Argentina", "Australia", "Brazil", "Canada", "China", "France", "Germany", "India", "Japan", "Mexico", "Russia", "United Kingdom", "United States"];

	private Task<IEnumerable<string>> SearchCountries(string query)
	{
		return Task.FromResult(_allCountries.Where(c => c.Contains(query, StringComparison.OrdinalIgnoreCase)));
	}

	private double _sliderValue = 50;
	private double _rangeStart = 25;
	private double _rangeEnd = 75;
	private int _rating = 3;
	private IList<string> _tags = new List<string>(["Blazor", "C#", "Moka.Red"]);
	private string _radioValue = "option1";

	// Commerce & data entry demo fields
	private string _ccNumber = "";
	private string _ccExpiry = "";
	private string _ccCvv = "";
	private string _ccName = "";
