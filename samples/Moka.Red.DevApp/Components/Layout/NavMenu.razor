@namespace Moka.Red.DevApp.Components.Layout

<MokaFlexbox Direction="MokaDirection.Column" Gap="MokaSpacingScale.Sm" Style="padding: var(--moka-spacing-sm);">
	<MokaSegmentedControl @bind-Value="_view" Size="MokaSize.Xs" FullWidth>
		<MokaSegment Value="all" Text="All"/>
		<MokaSegment Value="categories" Text="Categories"/>
	</MokaSegmentedControl>
</MokaFlexbox>

@if (_view == "all")
{
	<MokaMenu Dense>
		@foreach (var item in _allComponents)
		{
			<MokaMenuItem Text="@item.Name" Href="@item.Href" Active="@IsActive(item.Href)"/>
		}
	</MokaMenu>
}
else
{
	<MokaMenu Dense>
		<MokaMenuItem Text="Overview" Href="/" Icon="MokaIcons.Navigation.Home" Active="@IsActive("/")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">FOUNDATION</MokaCaption>
		<MokaMenuItem Text="Theme & Tokens" Icon="MokaIcons.Action.Settings" Href="/theme" Active="@IsActive("/theme")"/>
		<MokaMenuItem Text="Primitives" Href="/primitives" Active="@IsActive("/primitives")"/>
		<MokaMenuItem Text="Layout" Href="/layout" Active="@IsActive("/layout")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">INPUT & FORMS</MokaCaption>
		<MokaMenuItem Text="Forms" Href="/forms" Active="@IsActive("/forms")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">FEEDBACK & OVERLAY</MokaCaption>
		<MokaMenuItem Text="Feedback" Href="/feedback" Active="@IsActive("/feedback")"/>
		<MokaMenuItem Text="Context Menu" Href="/context-menu" Active="@IsActive("/context-menu")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">DATA & NAVIGATION</MokaCaption>
		<MokaMenuItem Text="Data" Href="/data" Active="@IsActive("/data")"/>
		<MokaMenuItem Text="Navigation" Href="/navigation" Active="@IsActive("/navigation")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">MEDIA & MISC</MokaCaption>
		<MokaMenuItem Text="Media" Href="/media" Active="@IsActive("/media")"/>
		<MokaMenuItem Text="Misc" Href="/misc" Active="@IsActive("/misc")"/>

		<MokaDivider Margin="MokaSpacingScale.Xs"/>
		<MokaCaption Class="nav-category">TOOLS</MokaCaption>
		<MokaMenuItem Text="Dock Layout" Href="/dock" Active="@IsActive("/dock")"/>
		<MokaMenuItem Text="Theme Editor" Href="/theme-editor" Active="@IsActive("/theme-editor")"/>
	</MokaMenu>
}

@code {
	[Inject] private NavigationManager Nav { get; set; } = default!;

	private string _view = "categories";

	private bool IsActive(string href)
	{
		var path = href.Contains('#') ? href[..href.IndexOf('#')] : href;
		return Nav.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase) ||
		       (path == "/" && Nav.Uri.EndsWith(Nav.BaseUri.TrimEnd('/')));
	}

