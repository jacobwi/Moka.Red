@inherits LayoutComponentBase

<MokaThemeProvider Theme="_theme">
	<MokaFlexbox Direction="MokaDirection.Row" Style="min-height: 100vh;">
		<MokaSidebar Open="true" Width="220px" Bordered>
			<Header>
				<MokaFlexbox Direction="MokaDirection.Row" Align="MokaAlign.Center" Gap="MokaSpacingScale.Sm" Padding="MokaSpacingScale.Sm">
					<div class="app-logo">M</div>
					<MokaFlexbox Direction="MokaDirection.Column" Gap="MokaSpacingScale.None">
						<MokaText Element="span" Weight="MokaFontWeight.Bold" Size="MokaSize.Md">Moka.Red</MokaText>
						<MokaCaption Class="app-version">v0.1.7</MokaCaption>
					</MokaFlexbox>
				</MokaFlexbox>
			</Header>
			<ChildContent>
				<NavMenu/>
			</ChildContent>
			<Footer>
				<MokaFlexbox Direction="MokaDirection.Row" Align="MokaAlign.Center" Justify="MokaJustify.SpaceBetween" Padding="MokaSpacingScale.Sm">
					<MokaCaption Class="app-footer-text">.NET 9 + 10</MokaCaption>
					<MokaCaption Class="app-footer-text">210+ components</MokaCaption>
				</MokaFlexbox>
			</Footer>
		</MokaSidebar>
		<MokaFlexbox Direction="MokaDirection.Column" Style="flex: 1; min-width: 0;">
			<MokaAppBar Dense Bordered>
				<StartContent>
					<MokaText Element="span" Size="MokaSize.Sm" Weight="MokaFontWeight.Medium" Style="color: var(--moka-color-on-surface-tertiary);">
						Component Library
					</MokaText>
				</StartContent>
				<EndContent>
					<MokaButton Variant="MokaVariant.Outlined" Size="MokaSize.Xs" OnClick="ToggleTheme">
						<MokaIcon Icon="MokaIcons.Toggle.Eye" SizeValue="14px"/>
						@(_isDark ? "Light" : "Dark")
					</MokaButton>
				</EndContent>
			</MokaAppBar>
			<MokaContainer Fluid Padding="MokaSpacingScale.Lg" Style="flex: 1; overflow-y: auto;">
				@Body
			</MokaContainer>
		</MokaFlexbox>
	</MokaFlexbox>
	<MokaToastHost/>
	<MokaDialogHost/>
	<MokaCommandPalette/>
	<MokaDiagnosticsOverlay Theme="_theme"/>
</MokaThemeProvider>

@code {
	private bool _isDark = true;
	private MokaTheme _theme = MokaTheme.Dark;

	private void ToggleTheme()
	{
		_isDark = !_isDark;
		_theme = _isDark ? MokaTheme.Dark : MokaTheme.Light;
	}

}
